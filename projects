# Mini-Projects-front-end-
Build solid frontend projects and make some clones.
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChatGPT Clone</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#202123;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.chat-container{
    width:450px;
    height:650px;
    background:#343541;
    border-radius:10px;
    overflow:hidden;
    display:flex;
    flex-direction:column;
}

.header{
    background:#10a37f;
    color:white;
    text-align:center;
    padding:15px;
    font-size:22px;
    font-weight:bold;
}

.chat-box{
    flex:1;
    padding:15px;
    overflow-y:auto;
}

.message{
    padding:10px;
    margin:10px 0;
    border-radius:10px;
    max-width:80%;
}

.user{
    background:#10a37f;
    color:white;
    margin-left:auto;
}

.bot{
    background:#444654;
    color:white;
}

.input-area{
    display:flex;
    padding:10px;
    background:#40414f;
}

input{
    flex:1;
    padding:12px;
    border:none;
    outline:none;
    border-radius:5px;
}

button{
    margin-left:10px;
    padding:12px 18px;
    border:none;
    background:#10a37f;
    color:white;
    border-radius:5px;
    cursor:pointer;
}

button:hover{
    background:#0e8d6d;
}
</style>
</head>

<body>

<div class="chat-container">
    <div class="header">ChatGPT Clone</div>

    <div class="chat-box" id="chatBox">
        <div class="message bot">
            Hello! I'm your AI Assistant.
        </div>
    </div>

    <div class="input-area">
        <input type="text" id="userInput" placeholder="Ask anything..."
               onkeypress="if(event.key==='Enter') sendMessage()">
        <button onclick="sendMessage()">Send</button>
    </div>
</div>

<script>
function sendMessage() {

    let input = document.getElementById("userInput");
    let text = input.value.trim();

    if(text === "") return;

    let chatBox = document.getElementById("chatBox");

    let userMsg = document.createElement("div");
    userMsg.classList.add("message","user");
    userMsg.textContent = text;
    chatBox.appendChild(userMsg);

    input.value = "";

    setTimeout(() => {

        let botReply = "";

        if(text.toLowerCase().includes("hello")){
            botReply = "Hello Prajwal! How can I help you today?";
        }
        else if(text.toLowerCase().includes("html")){
            botReply = "HTML is used to create the structure of web pages.";
        }
        else if(text.toLowerCase().includes("css")){
            botReply = "CSS is used to style web pages.";
        }
        else if(text.toLowerCase().includes("javascript")){
            botReply = "JavaScript adds interactivity to websites.";
        }
        else{
            botReply = "You typed: " + text;
        }

        let botMsg = document.createElement("div");
        botMsg.classList.add("message","bot");
        botMsg.textContent = botReply;

        chatBox.appendChild(botMsg);
        chatBox.scrollTop = chatBox.scrollHeight;

    },1000);

    chatBox.scrollTop = chatBox.scrollHeight;
}
</script>

</body>
</html>
